# ローカル開発用。terraform apply 完了後、`terraform output` の値をここに設定し
# ファイル名を .env.local にリネームする（.env.local はgit管理対象外）
# CI/CDでの本番ビルドは同じ値をGitHub repo Variables(PHASE3_*)経由で注入する
# （.github/workflows/deploy-03-frontend.yml参照）
REACT_APP_AWS_REGION=ap-northeast-1
REACT_APP_COGNITO_USER_POOL_ID=
REACT_APP_COGNITO_CLIENT_ID=
REACT_APP_API_ENDPOINT=
